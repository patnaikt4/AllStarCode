# Supabase (required for auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (required for feedback + embedding scripts under scripts/)
OPENAI_API_KEY=

# Optional: max tokens for lesson-plan feedback (default 4096; raise if output still truncates)
# OPENAI_FEEDBACK_MAX_OUTPUT_TOKENS=4096

# Storage bucket for generated feedback PDFs (default: documents)
# FEEDBACK_STORAGE_BUCKET=documents

# Optional: scripts/generate_embeddings.py if anon cannot insert into curriculum_chunks
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: max duration in seconds for admin-owned video uploads. Leave empty for unlimited.
# ADMIN_MAX_VIDEO_SECONDS=
